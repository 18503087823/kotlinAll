<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_demo.xml — 实战练习页 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical"
    android:background="#F5F5F5" android:padding="24dp">

    <TextView android:text="🚀" android:textSize="64sp" android:layout_marginBottom="16dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="实战练习" android:textSize="22sp" android:textStyle="bold"
        android:textColor="#333" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
    <TextView android:text="真实 Retrofit API 网络请求\n完整的 MVVM 架构演示"
        android:textSize="14sp" android:textColor="#777" android:gravity="center"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:lineSpacingMultiplier="1.5" android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPostList" android:layout_width="220dp"
        android:layout_height="54dp" android:text="文章列表 (MVVM Demo)"
        android:textColor="#FFF" android:backgroundTint="#FF6F00"
        app:cornerRadius="12dp" android:textSize="15sp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWeatherDetail" android:layout_width="220dp"
        android:layout_height="54dp" android:text="天气详情 (今日)"
        android:textColor="#FFF" android:backgroundTint="#0D47A1"
        app:cornerRadius="12dp" android:textSize="15sp" />
</LinearLayout>
