<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_profile.xml — 个人中心（头像 + 功能列表） -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F5F5F5">

    <!-- ═══ 头像区域 ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#6200EE"
        android:paddingTop="40dp"
        android:paddingBottom="28dp">

        <!-- 圆形头像 — 点击换头像 -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatar"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:scaleType="centerCrop"
            android:clickable="true"
            android:focusable="true"
            app:shapeAppearanceOverlay="@style/CircleAvatar"
            android:background="@drawable/bg_splash_icon"
            android:contentDescription="点击更换头像" />

        <!-- 换头像文字提示 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击头像更换"
            android:textSize="11sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginTop="6dp" />

        <!-- 用户名 -->
        <TextView
            android:id="@+id/tvNickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kotlin 学习者"
            android:textSize="18sp"
            android:textColor="#FFF"
            android:layout_marginTop="14dp" />

        <!-- 知识点统计 -->
        <TextView
            android:id="@+id/tvKnowledgeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已掌握 23 个知识点"
            android:textSize="13sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- ═══ 功能菜单 ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFF"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 拍照换头像 -->
            <LinearLayout
                android:id="@+id/itemCamera"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:text="📷"
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="拍照换头像"
                    android:textSize="15sp"
                    android:textColor="#333"
                    android:layout_marginLeft="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView
                    android:text="→"
                    android:textSize="18sp"
                    android:textColor="#CCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#EEE" android:layout_marginHorizontal="16dp"/>

            <!-- 相册选头像 -->
            <LinearLayout
                android:id="@+id/itemGallery"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:text="🖼️"
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="相册选头像"
                    android:textSize="15sp"
                    android:textColor="#333"
                    android:layout_marginLeft="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView
                    android:text="→"
                    android:textSize="18sp"
                    android:textColor="#CCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#EEE" android:layout_marginHorizontal="16dp"/>

            <!-- 分享给好友 -->
            <LinearLayout
                android:id="@+id/itemShare"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:text="📤"
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="分享给好友"
                    android:textSize="15sp"
                    android:textColor="#333"
                    android:layout_marginLeft="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView
                    android:text="→"
                    android:textSize="18sp"
                    android:textColor="#CCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#EEE" android:layout_marginHorizontal="16dp"/>

            <!-- 退出登录 -->
            <LinearLayout
                android:id="@+id/itemLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:text="🚪"
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="退出登录"
                    android:textSize="15sp"
                    android:textColor="#D32F2F"
                    android:layout_marginLeft="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView
                    android:text="→"
                    android:textSize="18sp"
                    android:textColor="#CCC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 版本号 -->
    <TextView
        android:text="v1.0.0"
        android:textSize="12sp"
        android:textColor="#BBB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"/>
</LinearLayout>
