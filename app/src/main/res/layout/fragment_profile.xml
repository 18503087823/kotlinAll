<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_profile.xml — 个人中心 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F5F5F5">

    <!-- 头像区 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:background="#6200EE" android:padding="36dp">
        <TextView android:layout_width="72dp" android:layout_height="72dp"
            android:text="K" android:textSize="30sp" android:textStyle="bold"
            android:textColor="#6200EE" android:gravity="center"
            android:background="@drawable/bg_splash_icon" />
        <TextView android:text="Kotlin 学习者" android:textSize="18sp"
            android:textColor="#FFF" android:layout_marginTop="12dp" />
        <TextView android:text="已掌握 23 个知识点" android:textSize="13sp"
            android:textColor="#AAFFFFFF" android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 功能列表 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="#FFF"
        android:layout_margin="16dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical">

            <LinearLayout android:id="@+id/itemLogout"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingHorizontal="16dp" android:clickable="true"
                android:focusable="true" android:background="?attr/selectableItemBackground">
                <TextView android:text="🚪" android:textSize="20sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="退出登录" android:textSize="15sp"
                    android:textColor="#D32F2F" android:layout_marginLeft="12dp"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView android:text="→" android:textSize="18sp" android:textColor="#CCC"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView android:text="v1.0.0" android:textSize="12sp" android:textColor="#BBB"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:layout_marginTop="8dp"/>
</LinearLayout>
