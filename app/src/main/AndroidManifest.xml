<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络请求权限（Retrofit 访问 API 需要） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.KotlinLearn">

        <!-- 引导页 — 首次启动时展示 3 个滑动页面 -->
        <activity
            android:name=".GuideActivity"
            android:exported="false" />

        <!-- 登录页 — POST 请求验证账号密码 -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- 知识点详情页 -->
        <activity
            android:name=".DetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- MVVM Demo：文章列表页 -->
        <activity
            android:name=".mvvm.ui.list.PostListActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- MVVM Demo：文章详情页 -->
        <activity
            android:name=".mvvm.ui.detail.PostDetailActivity"
            android:exported="false"
            android:parentActivityName=".mvvm.ui.list.PostListActivity" />

        <!-- 主页 — 23 个知识点卡片 -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:parentActivityName=".LoginActivity" />

        <!-- 启动页 — 应用入口，带进入动画，判断首次/回访 -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KotlinLearn.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
