<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络请求权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 拍照权限（头像功能） -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- 高德地图/导航所需权限 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- 后台定位（可选） -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Android 11+ 必须声明要查询的应用 -->
    <queries>
        <package android:name="com.tencent.mm" />
        <package android:name="com.tencent.mobileqq" />
        <package android:name="com.qzone" />
        <!-- 高德地图 — 导航跳转检测 -->
        <package android:name="com.autonavi.minimap" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="amapuri" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="androidamap" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.KotlinLearn">

        <!-- 高德 API Key -->
        <meta-data
            android:name="com.amap.api.v2.apikey"
            android:value="a8eae19e3637dc7789d3612102842ba1" />

        <!-- FileProvider — 拍照 + 分享 共用 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- 微信回调 Activity（必须放在 包名.wxapi 下） -->
        <activity
            android:name=".wxapi.WXEntryActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- 引导页 -->
        <activity android:name=".GuideActivity" android:exported="false" />

        <!-- 登录页 -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 知识点详情页 -->
        <activity
            android:name=".DetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".CodeExampleActivity"
            android:exported="false"
            android:parentActivityName=".DetailActivity" />

        <!-- MVVM Demo：文章列表页 -->
        <activity
            android:name=".mvvm.ui.list.PostListActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- MVVM Demo：文章详情页 -->
        <activity
            android:name=".mvvm.ui.detail.PostDetailActivity"
            android:exported="false"
            android:parentActivityName=".mvvm.ui.list.PostListActivity" />

        <!-- 天气详情页 -->
        <activity
            android:name=".ui.weather.WeatherDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- 图表演示页 — MPAndroidChart 库功能展示 -->
        <activity
            android:name=".ui.chart.ChartDemoActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- 导航演示页 — 高德地图导航 -->
        <activity
            android:name=".ui.navi.NaviDemoActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- 主页 -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:parentActivityName=".LoginActivity" />

        <!-- 启动页 -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KotlinLearn.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 高德定位 Service（必选） -->
        <service android:name="com.amap.api.location.APSService" />
    </application>
</manifest>
